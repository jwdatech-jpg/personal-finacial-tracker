# Database
# Local: postgresql://user:password@localhost:5432/financial_tracker
# Vercel: Use database provider (Vercel Postgres, Neon, Railway, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/financial_tracker

# JWT - Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Environment
NODE_ENV=development
PORT=5000

# CORS - Automatically handled by Vercel
CLIENT_URL=http://localhost:5173
VERCEL_URL=

# Email (Optional - for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
